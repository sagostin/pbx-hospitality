# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=hospitality
DB_PASSWORD=your_secure_password_here
DB_NAME=hospitality
DB_SSL_MODE=require

# Encryption
ENCRYPTION_MASTER_KEY=your_32_byte_master_key_here

# Server Configuration
SERVER_PORT=8080
ADMIN_API_KEY=your_admin_api_key_here

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Loki Configuration
LOKI_ENABLED=true
LOKI_ENDPOINT=https://loki.example.com/loki/api/v1/push

# Service Identity
SERVICE_NAME=bicom-hospitality
ENV=production
HOSTNAME=pbx-server-01

# PMS Configuration (example)
# PMS_HOST=localhost
# PMS_PORT=5000