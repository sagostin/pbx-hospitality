# =============================================================================
# pbx-hospitality — environment configuration
# =============================================================================
# Copy to .env and edit. Only environment variables are read by the service at
# runtime; YAML files are reference templates only (see config/example.yaml).

# --- Database ----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=hospitality
DB_PASSWORD=change-me
DB_NAME=hospitality
# require | verify-full | disable
DB_SSL_MODE=require

# --- Encryption (required) ---------------------------------------------------
# Base64-encoded 32-byte AES-256 key. Generate with:
#   openssl rand -base64 32
# Required at startup. ARI passwords are encrypted with this key.
ENCRYPTION_MASTER_KEY=

# --- Server ------------------------------------------------------------------
SERVER_PORT=8080
# Required for any /admin/* call. Header name: X-Admin-Key.
ADMIN_API_KEY=

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info          # debug | info | warn | error
LOG_FORMAT=json         # json | console
# Loki configuration
LOKI_ENABLED=false
LOKI_ENDPOINT=https://loki.example.com/loki/api/v1/push

# --- Identity (used in logs and the WS log-sink auth token) ------------------
SERVICE_NAME=bicom-hospitality
ENV=production

# =============================================================================
# site-connector (only used by the standalone edge binary)
# =============================================================================
# site-connector reads its full config from config/config.yaml under the
# site_connectors key (see config/example.yaml). It does NOT use these vars.

# =============================================================================
# Notes
# =============================================================================
# - Tenants and PBX systems are configured in the database and managed via
#   the Admin API (/admin/tenants, /admin/sites, /admin/bicom-systems).
#   They are NOT set via env vars.
# - ENCRYPTION_MASTER_KEY must be set or the service refuses to start.
# - The service auto-migrates the schema on first start.